# Fastfile — iOS release automation for Glev.
#
# This replaces the old "open Xcode, bump version by hand, Product > Archive,
# Distribute App > App Store Connect > Upload" dance with single-command lanes:
#
#   bundle exec fastlane ios beta            # auto-bump build, archive, upload to TestFlight
#   bundle exec fastlane ios beta bump:patch # also bump MARKETING_VERSION x.y -> x.(y+1).0
#   bundle exec fastlane ios release         # promote latest TestFlight build to App Store
#   bundle exec fastlane ios bump build      # just bump CURRENT_PROJECT_VERSION (no build)
#   bundle exec fastlane ios bump marketing kind:patch
#
# All lanes assume macOS + Xcode 15+. They use the App Store Connect API key
# for auth (no 2FA prompts), driven by these env vars (export them or put them
# in `~/.fastlane/.env` — never commit them):
#
#   APP_STORE_CONNECT_API_KEY_ID         e.g. ABCD1234EF
#   APP_STORE_CONNECT_API_ISSUER_ID      Issuer UUID from App Store Connect
#   APP_STORE_CONNECT_API_KEY_BASE64     base64(`cat AuthKey_<id>.p8`)
#                                        (or use APP_STORE_CONNECT_API_KEY_PATH
#                                        to point at the .p8 file directly)
#
# Code signing (fastlane match):
#   MATCH_GIT_URL      — SSH or HTTPS URL of the private certificates repo
#   MATCH_PASSWORD     — passphrase to decrypt certs/profiles from that repo
#
# When MATCH_GIT_URL is set the beta lane runs `match appstore` (readonly on CI)
# before archiving, installs the Distribution cert + App Store profile, and
# builds with CODE_SIGN_STYLE=Manual.
# When MATCH_GIT_URL is NOT set (developer Mac with Xcode automatic signing),
# the match step is skipped and Xcode manages signing automatically.
#
# Optional:
#   APP_IDENTIFIER, FASTLANE_APPLE_ID, FASTLANE_TEAM_ID, FASTLANE_ITC_TEAM_ID
#   GYM_EXPORT_METHOD (defaults to "app-store")
#
# The version-bump step shells out to `node scripts/bump-ios-version.mjs` so
# the same logic is testable on Linux/Replit (where Xcode is unavailable).

default_platform(:ios)

# ---------------------------------------------------------------------------
# Android helpers (used by the platform :android block below)
# ---------------------------------------------------------------------------

ANDROID_DIR      = File.expand_path("../android", __dir__)
BUILD_GRADLE     = File.expand_path("../android/app/build.gradle", __dir__)

def bump_android_via_node(*args)
  Dir.chdir(REPO_ROOT) do
    sh("node", "scripts/bump-android-version.mjs", *args)
  end
end

def current_android_versions
  text = File.read(BUILD_GRADLE)
  code = text[/\bversionCode\s+(\d+)\b/, 1]
  name = text[/\bversionName\s+"([^"]+)"/, 1]
  { version_name: name, version_code: code }
end

def play_store_json_key
  if ENV["PLAY_STORE_JSON_KEY_DATA"].to_s.empty? &&
     ENV["PLAY_STORE_JSON_KEY_PATH"].to_s.empty?
    UI.user_error!(
      "Play Store JSON key not configured. Set PLAY_STORE_JSON_KEY_DATA " \
      "(base64 of service-account JSON) or PLAY_STORE_JSON_KEY_PATH " \
      "(path to the JSON file). See fastlane/README.md.",
    )
  end
  ENV["PLAY_STORE_JSON_KEY_DATA"] || ENV["PLAY_STORE_JSON_KEY_PATH"]
end

XCODEPROJ = File.expand_path("../ios/App/App.xcodeproj", __dir__)
WORKSPACE = File.expand_path("../ios/App/App.xcworkspace", __dir__)
SCHEME    = "App"
REPO_ROOT = File.expand_path("..", __dir__)

def app_store_connect_key
  if ENV["APP_STORE_CONNECT_API_KEY_ID"].to_s.empty? ||
     ENV["APP_STORE_CONNECT_API_ISSUER_ID"].to_s.empty?
    UI.user_error!(
      "App Store Connect API key not configured. Set APP_STORE_CONNECT_API_KEY_ID, " \
      "APP_STORE_CONNECT_API_ISSUER_ID and either APP_STORE_CONNECT_API_KEY_BASE64 " \
      "or APP_STORE_CONNECT_API_KEY_PATH. See fastlane/README.md.",
    )
  end

  params = {
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
    in_house: false,
  }
  if ENV["APP_STORE_CONNECT_API_KEY_BASE64"]
    params[:key_content] = ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64")
    params[:is_key_content_base64] = true
  elsif ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    params[:key_filepath] = ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH")
  else
    UI.user_error!(
      "Provide either APP_STORE_CONNECT_API_KEY_BASE64 or APP_STORE_CONNECT_API_KEY_PATH",
    )
  end
  app_store_connect_api_key(**params)
end

def bump_via_node(*args)
  Dir.chdir(REPO_ROOT) do
    sh("node", "scripts/bump-ios-version.mjs", *args)
  end
end

def current_versions
  marketing = get_version_number_from_xcodeproj(xcodeproj: XCODEPROJ, target: SCHEME)
  build     = get_build_number_from_xcodeproj(xcodeproj: XCODEPROJ, target: SCHEME)
  { marketing: marketing, build: build }
end

platform :ios do
  before_all do
    unless File.exist?(File.join(XCODEPROJ, "project.pbxproj"))
      UI.user_error!("Cannot find #{XCODEPROJ}. Run `npx cap sync ios` first.")
    end
  end

  desc "Print MARKETING_VERSION + CURRENT_PROJECT_VERSION as currently committed"
  lane :versions do
    v = current_versions
    UI.message("MARKETING_VERSION = #{v[:marketing]}")
    UI.message("CURRENT_PROJECT_VERSION = #{v[:build]}")
  end

  desc "Bump versions only. Examples: `fastlane ios bump build`, `fastlane ios bump marketing kind:patch`"
  lane :bump do |options|
    case options[:type] || ARGV.last
    when "marketing"
      kind = options[:kind] || "patch"
      bump_via_node("marketing", kind)
    when "release"
      kind = options[:kind] || "patch"
      bump_via_node("release", kind)
    else
      bump_via_node("build")
    end
  end

  desc "Build a release archive and upload to TestFlight."
  desc "Options:"
  desc "  bump:patch|minor|major  — also bump MARKETING_VERSION (resets build to 1)"
  desc "  bump:build (default)    — just increment CURRENT_PROJECT_VERSION"
  desc "  skip_bump:true          — don't touch versions at all (use what's committed)"
  lane :beta do |options|
    api_key = app_store_connect_key

    unless options[:skip_bump]
      kind = options[:bump] || "build"
      if %w[patch minor major].include?(kind)
        bump_via_node("release", kind)
      else
        # Sync to TestFlight first so we never collide with an already-uploaded
        # build number for the current marketing version.
        marketing = get_version_number_from_xcodeproj(xcodeproj: XCODEPROJ, target: SCHEME)
        latest = latest_testflight_build_number(
          api_key: api_key,
          version: marketing,
          initial_build_number: 0,
          live: false,
        )
        bump_via_node("build", "--set", (latest.to_i + 1).to_s)
      end
    end

    UI.success("Building #{current_versions[:marketing]} (#{current_versions[:build]})")

    # Capacitor copies webDir + plugin manifest into ios/App/App/public.
    # Run this from REPO_ROOT so the local @capacitor/cli is found.
    Dir.chdir(REPO_ROOT) { sh("npx", "cap", "sync", "ios") }

    # Code signing via fastlane match.
    # When MATCH_GIT_URL is set (always on CI, optionally on dev Macs) match
    # fetches the Distribution cert + App Store provisioning profile from the
    # private certificates repo, installs them into the keychain, and we build
    # with CODE_SIGN_STYLE=Manual so Xcode doesn't try to regenerate them.
    # When MATCH_GIT_URL is absent (developer Mac with automatic signing), this
    # block is skipped entirely and Xcode manages signing as before.
    use_match = ENV["MATCH_GIT_URL"].to_s.strip != ""
    if use_match
      match(
        type: "appstore",
        readonly: is_ci,
      )
    end

    build_params = {
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: ENV.fetch("GYM_EXPORT_METHOD", "app-store"),
      output_directory: File.join(REPO_ROOT, "build", "ios"),
      clean: true,
      include_symbols: true,
      include_bitcode: false,
    }
    # Manual signing is required when match has installed the cert/profile.
    build_params[:xcargs] = "CODE_SIGN_STYLE=Manual" if use_match

    build_app(**build_params)

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TESTFLIGHT_CHANGELOG"] ||
                 "Automated build #{current_versions[:marketing]} (#{current_versions[:build]})",
    )

    UI.success("Uploaded to TestFlight: #{current_versions[:marketing]} (#{current_versions[:build]})")
  end

  desc "Promote the latest TestFlight build to App Store production (no rebuild)."
  lane :release do
    api_key = app_store_connect_key
    deliver(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true,
      skip_binary_upload: true,
      precheck_include_in_app_purchases: false,
    )
    UI.success("Promoted latest TestFlight build to App Store. Submit for review in App Store Connect.")
  end
end

# ---------------------------------------------------------------------------
# Android platform
#
# Usage (on any machine with JDK 17, Node 20, and Android SDK available):
#
#   bundle exec fastlane android beta            # bump versionCode, build AAB, upload to internal track
#   bundle exec fastlane android beta bump:patch # also bump versionName patch + reset versionCode to 1
#   bundle exec fastlane android beta skip_bump:true  # build + upload without touching versions
#   bundle exec fastlane android release         # promote internal → production (no rebuild)
#   bundle exec fastlane android bump            # just bump versionCode (no build)
#   bundle exec fastlane android bump type:marketing kind:patch
#
# Required env vars (export or put in ~/.fastlane/.env — never commit):
#
#   PLAY_STORE_JSON_KEY_DATA    base64(`cat service-account.json`)
#   KEYSTORE_PATH               absolute path to the release keystore
#   KEYSTORE_PASSWORD           keystore + key password
#   KEY_ALIAS                   key alias inside the keystore (e.g. "glev")
#   KEY_PASSWORD                same as KEYSTORE_PASSWORD (unless different)
#
# The Gradle signingConfigs block in android/app/build.gradle reads those four
# KEYSTORE_*/KEY_* env vars at build time, so no Fastfile edits are needed for
# signing — just export the vars.
# ---------------------------------------------------------------------------

platform :android do
  before_all do
    unless File.exist?(BUILD_GRADLE)
      UI.user_error!("Cannot find #{BUILD_GRADLE}. Run `npx cap sync android` first.")
    end
  end

  desc "Print versionName + versionCode as currently committed"
  lane :versions do
    v = current_android_versions
    UI.message("versionName  = #{v[:version_name]}")
    UI.message("versionCode  = #{v[:version_code]}")
  end

  desc "Bump versions only. Examples: `fastlane android bump`, `fastlane android bump type:marketing kind:patch`"
  lane :bump do |options|
    case options[:type] || ARGV.last
    when "marketing"
      kind = options[:kind] || "patch"
      bump_android_via_node("marketing", kind)
    when "release"
      kind = options[:kind] || "patch"
      bump_android_via_node("release", kind)
    else
      bump_android_via_node("build")
    end
  end

  desc "Build a signed release AAB and upload to Play Store internal track."
  desc "Options:"
  desc "  bump:patch|minor|major  — also bump versionName (resets versionCode to 1)"
  desc "  bump:build (default)    — just increment versionCode"
  desc "  skip_bump:true          — don't touch versions at all"
  lane :beta do |options|
    play_store_json_key  # validates env vars early, before long build

    unless options[:skip_bump]
      kind = options[:bump] || "build"
      if %w[patch minor major].include?(kind)
        bump_android_via_node("release", kind)
      else
        bump_android_via_node("build")
      end
    end

    v = current_android_versions
    UI.success("Building #{v[:version_name]} (#{v[:version_code]})")

    # Capacitor copies webDir + plugin manifest into android/app/src/main/assets/public.
    Dir.chdir(REPO_ROOT) { sh("npx", "cap", "sync", "android") }

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: ANDROID_DIR,
      print_command: true,
    )

    aab_path = File.join(
      ANDROID_DIR,
      "app", "build", "outputs", "bundle", "release", "app-release.aab",
    )

    json_key_data = ENV["PLAY_STORE_JSON_KEY_DATA"].to_s
    upload_params = {
      package_name: ENV.fetch("ANDROID_PACKAGE_NAME", "app.glev"),
      aab: aab_path,
      track: "internal",
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    }
    unless json_key_data.empty?
      upload_params[:json_key_data] = json_key_data
    else
      upload_params[:json_key] = ENV.fetch("PLAY_STORE_JSON_KEY_PATH")
    end

    upload_to_play_store(**upload_params)

    UI.success("Uploaded to Play Store (internal track): #{v[:version_name]} (#{v[:version_code]})")
  end

  desc "Promote the current internal-track build to production (no rebuild)."
  lane :release do
    json_key_data = ENV["PLAY_STORE_JSON_KEY_DATA"].to_s
    promote_params = {
      package_name: ENV.fetch("ANDROID_PACKAGE_NAME", "app.glev"),
      track: "internal",
      track_promote_to: "production",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    }
    unless json_key_data.empty?
      promote_params[:json_key_data] = json_key_data
    else
      promote_params[:json_key] = ENV.fetch("PLAY_STORE_JSON_KEY_PATH")
    end

    upload_to_play_store(**promote_params)
    UI.success("Promoted internal build to Play Store production. Review and publish in Play Console.")
  end
end
