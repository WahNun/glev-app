# Supabase project URL (e.g. https://abcdef.supabase.co)
SUPABASE_URL=

# Server-side service role key — bypasses RLS. NEVER expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# Anon (publishable) key — used to verify user JWTs.
SUPABASE_ANON_KEY=

# 32-byte (64 hex char) key for AES-256-GCM password encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Optional. Defaults to 8080.
PORT=8080
