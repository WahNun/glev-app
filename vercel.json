{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/process-queue",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/drip",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/cgm-poll",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cgm/nightscout/cron",
      "schedule": "*/10 * * * *"
    }
  ]
}
