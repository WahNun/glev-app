{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/hypo-check",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/elevated-check",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/hyper-check",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/flush-outbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/drip",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/drip-spike-check",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/cgm-poll",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/meal-hypo-check",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cgm/nightscout/cron",
