modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Inbox Daemon"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "engine-unit"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node node_modules/next/dist/bin/next dev -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm test"

[[workflows.workflow]]
name = "Inbox Daemon"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/inbox-daemon.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "engine-unit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PLAYWRIGHT_SKIP_WEBSERVER=1 node node_modules/@playwright/test/cli.js test tests/unit --project=chromium 2>&1"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-sheet:1.0.0", "todoist:1.0.0", "github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[nix]
channel = "stable-25_05"
packages = ["tree"]

[userenv]

