# Local overrides — never committed (see .gitignore)
# Copy values from Replit Secrets or Vercel Environment Variables.

# Asana Personal Access Token (asana.com → My Profile → Apps → PATs)
ASANA_PAT=

# Asana webhook HMAC signing secret (must match Vercel env var)
ASANA_WEBHOOK_SECRET=

# Comma-separated GIDs of all "Replit Queue" sections
ASANA_REPLIT_QUEUE_SECTION_IDS=
