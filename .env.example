# --- Existing Next.js / Supabase client (do not change) ---------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- CGM (LibreLinkUp) API routes — server-only ----------------------------
# Same project as NEXT_PUBLIC_SUPABASE_URL, just without the client prefix.
SUPABASE_URL=
# Same value as NEXT_PUBLIC_SUPABASE_ANON_KEY; used to verify user JWTs.
SUPABASE_ANON_KEY=
# Service role key — bypasses RLS. Server-only, never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=
# 32-byte (64 hex char) key for AES-256-GCM password encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Other server-side --------------------------------------------------------
SESSION_SECRET=
OPENAI_API_KEY=

# --- Site origin (used by Stripe Checkout success/cancel URLs) --------------
# In dev you can leave this empty (the route falls back to the request host).
# In production set to the canonical origin, e.g. https://glev.app — no trailing slash.
NEXT_PUBLIC_SITE_ORIGIN=

# --- Supabase Management API (only needed by `npm run db:migrate`) ----------
# Personal access token from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# --- Stripe (Test-Mode keys for /beta + /pro landing pages) -----------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# /beta — €19 one-time reservation
STRIPE_BETA_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# /pro — €24,90/month recurring subscription (separate webhook endpoint)
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_WEBHOOK_SECRET=
