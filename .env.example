# --- Feature flags -----------------------------------------------------------
# Phase 2: per-item source resolution via OFF/USDA/GPT aggregator.
MACRO_AGGREGATOR_V2=false
# Phase 3: emit meal_prep frame immediately (Mistral estimates), run aggregator
# detached, push refined sources via Supabase Realtime → badge swap ✨→✅.
OPTIMISTIC_REFINEMENT=false

# --- Existing Next.js / Supabase client (do not change) ---------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- CGM (LibreLinkUp) API routes — server-only ----------------------------
# Same project as NEXT_PUBLIC_SUPABASE_URL, just without the client prefix.
SUPABASE_URL=
# Same value as NEXT_PUBLIC_SUPABASE_ANON_KEY; used to verify user JWTs.
SUPABASE_ANON_KEY=
# Service role key — bypasses RLS. Server-only, never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=
# 32-byte (64 hex char) key for AES-256-GCM password encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Other server-side --------------------------------------------------------
SESSION_SECRET=
OPENAI_API_KEY=

# Bearer token for the email-outbox cron worker
# (`POST /api/cron/flush-outbox`). Must be ≥16 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: store this in Replit *Secrets* (not Env Vars), since the
# Env Vars tab persists into .replit which is committed to git.
CRON_SECRET=

# HMAC secret for signing the one-click unsubscribe links in the
# onboarding drip mails (Tag 7/14/30). Same generator as CRON_SECRET,
# must be ≥16 chars. If unset, the code falls back to CRON_SECRET so
# existing deployments keep working — but in production you should set
# a dedicated value so rotating one secret doesn't invalidate the other.
EMAIL_UNSUBSCRIBE_SECRET=

# --- Site origin (used by Stripe Checkout success/cancel URLs) --------------
# In dev you can leave this empty (the route falls back to the request host).
# In production set to the canonical origin, e.g. https://glev.app — no trailing slash.
NEXT_PUBLIC_SITE_ORIGIN=

# --- Supabase Management API (only needed by `npm run db:migrate`) ----------
# Personal access token from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# --- Asana (webhook receiver + queue scripts) --------------------------------
# Personal Access Token from asana.com → My Profile → Apps → PATs
ASANA_PAT=
# Random 32-byte hex secret — must match value used when registering webhooks
# Generate: openssl rand -hex 32
ASANA_WEBHOOK_SECRET=
# Comma-separated GIDs of all "Replit Queue" sections (output of asana-setup-webhooks.mjs)
ASANA_REPLIT_QUEUE_SECTION_IDS=

# --- Mistral AI -------------------------------------------------------------
# User-facing Glev AI (chat, insights, future meal/voice). Server-only.
MISTRAL_API_KEY=
# Dev Cockpit AI (Analyze Task / Re-Analyze / future build planning). Separate
# cost bucket. OPTIONAL — if unset, Dev Cockpit falls back to MISTRAL_API_KEY.
MISTRAL_DEV_COCKPIT_API_KEY=
# Optional override for the Dev Cockpit analysis model (default mistral-large-latest).
DEV_COCKPIT_ANALYSIS_MODEL=

# --- Stripe (Test-Mode keys for /beta + /pro landing pages) -----------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# /beta — €19 one-time reservation
STRIPE_BETA_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# /pro — €24,90/month recurring subscription (separate webhook endpoint)
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_WEBHOOK_SECRET=

# --- SMS Opt-Out (UWG/TKG compliance) ---------------------------------------
# 32-byte random secret for HMAC-signing the one-click unsubscribe tokens
# appended to every outbound marketing SMS (glev.app/sms-stop?t=…&u=…).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Set this in Vercel Dashboard → Project Settings → Environment Variables
# (production + preview + development).
SMS_UNSUB_SECRET=

# --- Secret rotation procedure ---
# If SMS_UNSUB_SECRET is ever compromised or must be rotated:
#   1. Generate a new secret (see command above).
#   2. In Vercel: set SMS_UNSUB_SECRET_PREV = <current value of SMS_UNSUB_SECRET>.
#   3. In Vercel: set SMS_UNSUB_SECRET   = <new secret>.
#   4. Deploy (Vercel picks up new env vars on the next build).
#      → Links signed with the old secret continue to work during this window.
#   5. After all previously sent SMS links have expired (typically 30–90 days,
#      depending on your campaign cadence), unset SMS_UNSUB_SECRET_PREV.
#      → Only the new secret is accepted from that point on.
# Only one previous secret is supported. If you need to rotate again before
# removing PREV, first remove PREV, then follow the steps above again.
SMS_UNSUB_SECRET_PREV=

# --- Admin panel (/glev-ops) -------------------------------------------------
# Marketer login — grants read-only access restricted to /glev-ops/crm.
# Both must be set for the marketer login to work; if either is missing
# the login silently falls through to the admin credential check.
# MARKETER_EMAIL must be a valid e-mail. MARKETER_PASSWORD must be ≥8 chars.
# Set these in Vercel Dashboard → Project Settings → Environment Variables.
MARKETER_EMAIL=
MARKETER_PASSWORD=
GITHUB_PAT=
