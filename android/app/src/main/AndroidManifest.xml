<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Health Connect package visibility. Required on Android 11+ (API 30+) so
      the app can call HealthConnectClient.getSdkStatus() and getOrCreate()
      without a PackageManager SecurityException.  This does not grant any
      permissions — it only makes the HC provider package visible to our app.
    -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:screenOrientation="unspecified"
            android:exported="true">
            <!--
              NATIVE BUILD REQUIRED: changing screenOrientation from "portrait"
              to "unspecified" is a Manifest change — a new signed AAB must be
              built and uploaded to the Play Store for this to take effect on
              devices. The JS-layer LandscapeGlucoseOverlay lock/unlock logic
              is already platform-agnostic and works on Android once landscape
              is permitted here.
            -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Required so Health Connect's permission rationale dialog can deep-link
              back into Glev.  Without this filter the in-app permission flow breaks
              on Android 14+ (HC shows an "open app settings" button that goes nowhere).
            -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!--
          GlucoseChangeReceiver is woken by Health Connect whenever new
          blood-glucose samples are written — even when Glev is closed.
          It immediately enqueues a one-shot GlucoseSyncWorker job, giving
          us near-real-time background sync analogous to iOS HKObserverQuery.

          exported="false" is correct: only Health Connect's own
          PendingIntent mechanism fires this receiver, not third-party apps.
        -->
        <receiver
            android:name=".GlucoseChangeReceiver"
            android:exported="false" />

        <!--
          AlarmKeepAliveService runs as a foreground service to prevent Android
          Doze/App-Standby from delaying FCM push delivery for hypo/hyper alarms.
          foregroundServiceType="health" is required on Android 14+ (API 34+) for
          health-related foreground services; it matches the FOREGROUND_SERVICE_HEALTH
          permission declared above and is silently ignored on older API levels.
          exported="false" — only started by MainActivity, not accessible to other apps.
        -->
        <service
            android:name=".AlarmKeepAliveService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="health" />

        <!--
          FCM default notification icon and colour.
          Without these, FCM-delivered notifications fall back to ic_launcher,
          which Android renders as a solid grey square in the status bar and
          notification shade (colour icons are not allowed there).
          ic_stat_glev is a white-on-transparent vector drawable (Glev network
          graph, 7 nodes / 10 edges) that displays correctly at any density.
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_glev" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/glev_accent" />

    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      POST_NOTIFICATIONS is required on Android 13+ (API 33+) for push
      notifications via FCM / @capacitor/push-notifications.
      On older API levels this permission is silently ignored.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      VIBRATE allows haptic feedback via @capacitor/haptics (SnapSlider,
      SaveButton, etc.). No runtime prompt is needed — it is a normal
      permission granted automatically at install time.
    -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
      RECORD_AUDIO enables microphone access for the hold-to-talk voice
      input in GlevAIChatSheet (useVoxtral hook). Capacitor bridges
      navigator.mediaDevices.getUserMedia to the native mic; Android
      requires this permission to be declared here AND granted at runtime
      (the browser/WebView triggers the native permission dialog the first
      time getUserMedia is called — no separate @capacitor/microphone
      plugin needed).
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
      Health Connect blood-glucose read permission.
      READ_BLOOD_GLUCOSE is the fine-grained permission that gates all
      HealthConnectClient calls related to blood glucose data.  The user
      must grant this at runtime via the Health Connect permission sheet
      (triggered from the JS layer in Settings → Health Connect).
      Without this grant, HealthConnectSyncRegistrar silently skips
      registration and GlucoseSyncWorker returns Result.success() early.
    -->
    <uses-permission android:name="android.permission.health.READ_BLOOD_GLUCOSE" />

    <!--
      ACCESS_NOTIFICATION_POLICY is required for NotificationChannel.setBypassDnd(true)
      to take effect.  Declaring the permission here is not sufficient on its own —
      the user must also grant "Do Not Disturb access" for Glev once in
      Settings → Apps → Glev → Notifications → Do Not Disturb access (or via
      Settings.ACTION_NOTIFICATION_POLICY_ACCESS_SETTINGS intent).  The in-app
      flow for this is a planned follow-up; this permission enables it.
    -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!--
      FOREGROUND_SERVICE is required to call startForegroundService() / startForeground().
      FOREGROUND_SERVICE_HEALTH is the Android 14+ (API 34+) type-specific permission
      for health-related foreground services.  On older API levels it is silently ignored.
      Both are install-time permissions — no runtime prompt is shown to the user.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />

</manifest>
